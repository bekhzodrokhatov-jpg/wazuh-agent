<!-- HW-Detector Custom Decoder for Wazuh v4.0 (Fixed) -->
<!-- Joylash: /var/ossec/etc/decoders/hw_detector_decoder.xml -->

<!-- HW-Detector scan natijasi (agent dan keladi) -->
<decoder name="hw_detector_manual">
  <prematch>hw_detector:</prematch>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>

<!-- Hardware o'zgarishi alerti (server Python skriptidan keladi) -->
<decoder name="hw_change_manual">
  <prematch>hw_change:</prematch>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>
