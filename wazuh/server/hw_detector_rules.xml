<!-- HW-Detector Custom Rules for Wazuh v6.0 -->

<group name="hw_detector,">

  <!-- ASOSIY RULE: Windows JSON fayldan syslog shaklida kelganda ushlash -->
  <rule id="100100" level="3">
    <!-- JSON decoder emas, to'g'ridan-to'g'ri substring qidiramiz -->
    <match>"scan_type":"hw_fraud_detection"|"scan_type": "hw_fraud_detection"</match>
    <description>HW-Detector: Hardware tekshiruvi amalga oshirildi (Xom JSON ushlandi)</description>
  </rule>

  <!-- TAMPERED: hardware soxtalashtirilgan! -->
  <rule id="100101" level="12">
    <if_sid>100100</if_sid>
    <match>"verdict":"TAMPERED"|"verdict": "TAMPERED"</match>
    <description>HW-DETECTOR OGOHLANTIRISH: Hardware soxtalashtirish aniqlandi!</description>
    <options>alert_by_email</options>
    <group>hw_fraud,</group>
  </rule>

  <!-- CLEAN: hamma narsa joyida -->
  <rule id="100102" level="3">
    <if_sid>100100</if_sid>
    <match>"verdict":"CLEAN"|"verdict": "CLEAN"</match>
    <description>HW-Detector: Hardware mos — Holat: HAQIQIY</description>
  </rule>

  <!-- CPU soxtalashtirish -->
  <rule id="100103" level="14">
    <if_sid>100101</if_sid>
    <match>"tampered":true|"tampered": true</match>
    <description>HW-DETECTOR XAVF: Komponent (CPU/RAM/GPU) SOXTALASHTIRILGAN!</description>
    <options>alert_by_email</options>
    <group>hw_fraud,cpu_tampered,</group>
  </rule>

  <!-- Registry tampering -->
  <rule id="100112" level="13">
    <if_sid>100100</if_sid>
    <match>"registry_tampered":true|"registry_tampered": true</match>
    <description>SOXTALASHTIRILGAN: Hardware registordan aniq o'zgartirilgan!</description>
    <options>alert_by_email</options>
    <group>hw_fraud,registry_tampered,</group>
  </rule>

</group>
